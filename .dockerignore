# Build artifacts / caches — rebuilt inside the image.
frontend/node_modules
frontend/dist
frontend/dist-standalone
**/__pycache__
**/*.pyc
**/*.pyo

# Local virtualenvs.
venv
.venv
env

# VCS / CI / editor.
.git
.github
.circleci
.idea
